FROM node:20-slim AS build

WORKDIR /app
COPY demo/package.json demo/package-lock.json ./
RUN npm ci
COPY demo/ .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY demo/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
